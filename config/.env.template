# ═══════════════════════════════════════════════════════════════
#  LinkedIn SDR Agent — API Keys & Credentials
#  Copy this to .env and fill in your real keys.
#  NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── OpenAI (required for GenAI features) ──────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Google Search API (for Google scraping) ───────────────────
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-custom-search-engine-id-here

# ── LinkedIn (for LinkedIn scraping) ──────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ── Anthropic (optional, for cross-checking) ──────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Vector Store (optional) ──────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=leadgen-embeddings

# ── Database (optional) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/leadgen

# ── CRM Integration (optional) ──────────────────────────────
HUBSPOT_API_KEY=your-hubspot-api-key-here
HUBSPOT_PORTAL_ID=your-hubspot-portal-id-here

SF_CLIENT_ID=your-salesforce-client-id
SF_CLIENT_SECRET=your-salesforce-client-secret
SF_USERNAME=your-salesforce-username
SF_PASSWORD=your-salesforce-password

# ── Email Notifications (SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=your-email@gmail.com
APPROVAL_EMAIL=aadil.shaikh@logixal.com
